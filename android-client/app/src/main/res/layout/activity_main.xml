<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALS_CORE"
            android:textColor="#00FF41"
            android:fontFamily="monospace"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ATOMIC LEDGER"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <View
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:background="#00FF41" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/statusBox"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_below="@id/header"
        android:layout_marginTop="40dp"
        android:background="#121212">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:alpha="0.3"
            android:src="@android:drawable/ic_menu_directions"
            app:tint="#00FF41" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="SYSTEM READY // LISTENING FOR INTERRUPTS"
            android:textColor="#00FF41"
            android:fontFamily="monospace"
            android:textSize="10sp" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/button"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:text="SENSORS ACTIVE: > 12.0 m/s²"
        android:textColor="#888888"
        android:fontFamily="monospace"
        android:textSize="12sp" />

    <Button
        android:id="@+id/button"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="30dp"
        android:backgroundTint="#00FF41"
        android:text="INITIALIZE TRANSFER"
        android:textColor="#000000"
        android:textStyle="bold"
        app:cornerRadius="4dp" />

</RelativeLayout>
